---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---
<Base
  title="MoodSketch — Your Daily Creative Ritual"
  description="Draw your mood instead of writing about it. MoodSketch is a daily sketch journal app with prompts, expressive tools, and a beautiful creative archive."
>
  <div class="min-h-screen">

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-mood-warm-white/80 backdrop-blur-xl border-b border-mood-coral/[0.06]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-10 py-5 flex items-center justify-between gap-2">
        <a href="https://sketchkit.app" class="text-xs sm:text-sm font-display font-medium text-sketch-gray hover:text-ink transition-colors duration-300 flex items-center gap-1.5 whitespace-nowrap">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SketchKit
        </a>
        <span class="hidden sm:inline font-mood font-bold text-ink tracking-tight text-lg leading-[1.1]">MoodSketch</span>
        <a href="https://fieldsketch.app" class="text-xs sm:text-sm font-display font-medium text-sketch-gray hover:text-ink transition-colors duration-300 flex items-center gap-1.5 whitespace-nowrap">
          FieldSketch
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="noise relative text-white pt-32 pb-44 px-6 md:px-10 overflow-hidden" style="background: linear-gradient(135deg, #F5764A 0%, #E8623A 35%, #D94420 70%, #b33a1c 100%);">
      <!-- Layered painterly atmosphere -->
      <div class="absolute top-0 left-0 w-full h-full">
        <div class="absolute top-[-5%] right-[-8%] w-[50%] h-[55%] rounded-full bg-white/[0.04] blur-[100px]"></div>
        <div class="absolute bottom-[-10%] left-[-5%] w-[45%] h-[50%] rounded-full bg-[#D94420]/30 blur-[90px]"></div>
        <div class="absolute top-[30%] left-[50%] -translate-x-1/2 w-[30%] h-[25%] rounded-full bg-mood-lavender/[0.04] blur-[80px]"></div>
      </div>
      <!-- Organic floating shapes -->
      <div class="absolute top-[20%] right-[12%] w-32 h-32 rounded-full border-2 border-white/[0.05] drift"></div>
      <div class="absolute bottom-[25%] left-[8%] w-20 h-20 rounded-full border border-white/[0.04] drift" style="animation-delay:-3s"></div>
      <div class="absolute top-[55%] right-[35%] w-12 h-12 rounded-full border border-white/[0.03] drift" style="animation-delay:-5s"></div>
      <!-- Scattered paint drops -->
      <svg class="absolute top-[18%] left-[15%] text-white/[0.04]" width="10" height="10"><circle cx="5" cy="5" r="5" fill="currentColor"/></svg>
      <svg class="absolute top-[65%] right-[18%] text-white/[0.06]" width="14" height="14"><circle cx="7" cy="7" r="7" fill="currentColor"/></svg>
      <svg class="absolute bottom-[15%] left-[40%] text-white/[0.03]" width="7" height="7"><circle cx="3.5" cy="3.5" r="3.5" fill="currentColor"/></svg>
      <svg class="absolute top-[40%] left-[6%] text-mood-lavender/[0.05]" width="8" height="8"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>

      <div class="max-w-4xl mx-auto text-center hero-stagger relative">
        <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-white/25 mb-12">For iPhone & Android</p>

        <div class="flex justify-center mb-10">
          <img src="/moodsketch-icon.png" alt="MoodSketch app icon"
               class="w-28 h-28 rounded-[28%] shadow-2xl shadow-black/25 ring-4 ring-white/[0.08]" />
        </div>

        <h1 class="font-mood font-extrabold tracking-[-0.015em] text-[clamp(2.75rem,12vw,7.5rem)] leading-[0.94] mb-8">
          MoodSketch
        </h1>

        <p class="text-white/80 text-2xl md:text-[1.9rem] font-display font-medium mb-5 leading-[1.2]">Your daily creative ritual.</p>

        <p class="text-white/35 text-lg max-w-md mx-auto leading-[1.7] mb-16 font-light">
          You don't have to write about your feelings. Draw them.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-9 py-4 rounded-2xl bg-white/20 backdrop-blur-sm border border-white/20 text-white font-display font-semibold text-[0.9rem] transition-all hover:bg-white/30">
            App Store &mdash; Coming Soon
          </button>
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-9 py-4 rounded-2xl bg-white/[0.08] backdrop-blur-sm border border-white/10 text-white/70 font-display font-medium text-[0.9rem] transition-all hover:bg-white/15">
            Google Play &mdash; Coming Soon
          </button>
        </div>
      </div>

      <!-- Bottom wave-like fade -->
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-mood-warm-white to-transparent" style="z-index:2"></div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="py-32 px-6 md:px-10 bg-mood-warm-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-mood-coral mb-5">Features</p>
          <h2 class="font-mood font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink leading-tight">What makes it <span class="brush-underline">different.</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-12 stagger-children">
          <div class="reveal text-center">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-coral/15 to-mood-marigold/10 flex items-center justify-center mx-auto mb-7">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#F5764A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3 class="font-mood font-bold tracking-tight text-xl text-ink mb-4">Daily Prompts</h3>
            <p class="text-sketch-gray leading-[1.8] text-[0.95rem]">A new sketch prompt every day. Something loose enough to interpret, specific enough to be a starting point. You never start from nothing.</p>
          </div>
          <div class="reveal text-center">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-marigold/15 to-mood-coral/10 flex items-center justify-center mx-auto mb-7">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#D94420" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </div>
            <h3 class="font-mood font-bold tracking-tight text-xl text-ink mb-4">Tag Your Mood</h3>
            <p class="text-sketch-gray leading-[1.8] text-[0.95rem]">Before you save, pick how you're feeling — Great, Good, Okay, Low, or Rough. Your sketches become a mood map over time.</p>
          </div>
          <div class="reveal text-center">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-lavender/30 to-mood-coral/10 flex items-center justify-center mx-auto mb-7">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#C3B1E1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            </div>
            <h3 class="font-mood font-bold tracking-tight text-xl text-ink mb-4">Build Your Streak</h3>
            <p class="text-sketch-gray leading-[1.8] text-[0.95rem]">Draw every day, watch your streak grow. Miss one, no guilt — just pick it back up. The ritual compounds into something worth keeping.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section class="noise py-32 px-6 md:px-10 relative" style="background: var(--mood-blush);">
      <svg class="absolute top-12 right-12 w-28 h-28 text-mood-coral/[0.04]" viewBox="0 0 112 112" fill="none">
        <circle cx="56" cy="56" r="44" stroke="currentColor" stroke-width="1.5" stroke-dasharray="10 8"/>
      </svg>
      <svg class="absolute bottom-16 left-16 w-16 h-16 text-mood-lavender/[0.06]" viewBox="0 0 64 64" fill="none">
        <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="1.5"/>
      </svg>

      <div class="max-w-3xl mx-auto relative">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-mood-coral mb-5">The Ritual</p>
          <h2 class="font-mood font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink leading-tight">How it works.</h2>
        </div>
        <div class="space-y-20">
          <div class="reveal flex gap-8 md:gap-10 items-start">
            <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-mood-coral to-mood-marigold text-white font-mood font-extrabold text-3xl flex items-center justify-center shadow-xl shadow-mood-coral/15">1</div>
            <div class="pt-2">
              <h3 class="font-mood font-bold tracking-tight text-2xl md:text-[1.65rem] text-ink mb-4">Get a prompt</h3>
              <p class="text-sketch-gray text-lg leading-[1.8]">Open the app. Today's prompt is waiting — a word, a feeling, a concept. Something loose enough to interpret, specific enough to be a starting point.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 md:gap-10 items-start" style="transition-delay: 0.12s">
            <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-mood-coral to-mood-marigold text-white font-mood font-extrabold text-3xl flex items-center justify-center shadow-xl shadow-mood-coral/15">2</div>
            <div class="pt-2">
              <h3 class="font-mood font-bold tracking-tight text-2xl md:text-[1.65rem] text-ink mb-4">Tag your mood & sketch</h3>
              <p class="text-sketch-gray text-lg leading-[1.8]">Pick how you're feeling. Then draw — with expressive brushes, curated color palettes, and pinch-to-zoom. No rules, no pressure.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 md:gap-10 items-start" style="transition-delay: 0.24s">
            <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-mood-lavender to-mood-coral/50 text-ink font-mood font-extrabold text-3xl flex items-center justify-center shadow-xl shadow-mood-lavender/15">3</div>
            <div class="pt-2">
              <h3 class="font-mood font-bold tracking-tight text-2xl md:text-[1.65rem] text-ink mb-4">Watch it grow</h3>
              <p class="text-sketch-gray text-lg leading-[1.8]">Each sketch joins your scrolling calendar gallery — tagged by mood, organized by month. Your streak keeps you coming back. Your archive makes it worth it.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== EMOTIONAL QUOTE ===== -->
    <section class="py-32 px-6 md:px-10 bg-mood-warm-white">
      <div class="max-w-3xl mx-auto text-center reveal">
        <svg class="mx-auto mb-8 text-mood-coral/12" width="56" height="56" viewBox="0 0 48 48" fill="currentColor">
          <path d="M14 24H8c0-6.627 5.373-12 12-12v6c-3.314 0-6 2.686-6 6zm20 0h-6c0-6.627 5.373-12 12-12v6c-3.314 0-6 2.686-6 6z"/>
        </svg>
        <p class="font-mood font-bold text-[1.75rem] md:text-[2.5rem] text-ink leading-[1.3] mb-8">
          Not every feeling has words.<br/>Some of them just need a <span class="brush-underline">brushstroke.</span>
        </p>
        <p class="text-sketch-gray text-lg">That's what MoodSketch is for.</p>
      </div>
    </section>

    <!-- ===== PRICING ===== -->
    <section class="py-32 px-6 md:px-10 bg-mood-warm-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-mood-coral mb-5">Pricing</p>
          <h2 class="font-mood font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink mb-4 leading-tight">Simple pricing.</h2>
          <p class="text-sketch-gray text-lg">Start free. Go pro when you're ready.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-7">
          <!-- Free -->
          <div class="reveal rounded-[1.5rem] p-9 border-2 border-light-rule bg-white">
            <p class="text-sketch-gray text-sm font-medium mb-3">Free</p>
            <p class="font-mood font-extrabold tracking-tight text-[3.5rem] text-ink leading-[0.95] mb-1">$0</p>
            <p class="text-sketch-gray text-sm mb-9">Forever free</p>
            <ul class="space-y-3.5 mb-9">
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral">&#10003;</span> Daily prompt</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral">&#10003;</span> Mood tagging</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral">&#10003;</span> Streak counter</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral">&#10003;</span> Curated color palettes</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral">&#10003;</span> Scrolling gallery archive</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/35"><span>&#10007;</span> Export (PDF/PNG)</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/35"><span>&#10007;</span> Custom themes</li>
            </ul>
            <button class="w-full py-4 rounded-2xl border-2 border-light-rule text-sketch-gray font-display font-semibold text-sm hover:border-mood-coral hover:text-mood-coral transition-colors duration-300">
              Coming soon
            </button>
          </div>
          <!-- Pro -->
          <div class="reveal relative overflow-hidden rounded-[1.5rem] p-9 text-white" style="background: linear-gradient(135deg, #F5764A 0%, #E8623A 40%, #D94420 100%); transition-delay: 0.1s">
            <div class="absolute top-0 right-0 w-44 h-44 bg-white/[0.04] rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative">
              <p class="text-white/60 text-sm font-medium mb-3">Pro</p>
              <p class="font-mood font-extrabold tracking-tight text-[3.5rem] leading-[0.95] mb-1">$2.99<span class="text-2xl font-normal text-white/50">/mo</span></p>
              <p class="text-white/40 text-sm mb-9">or $19.99/yr — save 44%</p>
              <ul class="space-y-3.5 mb-9">
                <li class="flex items-center gap-3 text-sm"><span>&#10003;</span> Everything in Free</li>
                <li class="flex items-center gap-3 text-sm"><span>&#10003;</span> Unlimited archive</li>
                <li class="flex items-center gap-3 text-sm"><span>&#10003;</span> Full prompt library</li>
                <li class="flex items-center gap-3 text-sm"><span>&#10003;</span> Export to PDF & PNG</li>
                <li class="flex items-center gap-3 text-sm"><span>&#10003;</span> Custom themes</li>
                <li class="flex items-center gap-3 text-sm"><span>&#10003;</span> Early access to new features</li>
              </ul>
              <button class="cta-pulse w-full py-4 rounded-2xl bg-white text-mood-coral font-display font-semibold text-sm hover:bg-white/90 transition-colors duration-300 shadow-xl shadow-mood-marigold/25">
                Coming soon
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== EMAIL CAPTURE ===== -->
    <section class="noise py-32 px-6 md:px-10 relative overflow-hidden" style="background: var(--mood-plum);">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] bg-mood-coral/[0.08] rounded-full blur-[130px]"></div>
      <svg class="absolute bottom-12 left-12 w-20 h-20 text-white/[0.02]" viewBox="0 0 80 80" fill="none">
        <path d="M16 40c16-32 48-32 48 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg class="absolute top-16 right-16 w-12 h-12 text-mood-coral/[0.04]" viewBox="0 0 48 48" fill="none">
        <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="1.5" stroke-dasharray="6 5"/>
      </svg>
      <div class="max-w-lg mx-auto text-center reveal relative">
        <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-mood-coral/35 mb-8">Waitlist</p>
        <h2 class="font-mood font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-white mb-5 leading-tight">Be first to draw.</h2>
        <p class="text-white/30 text-lg mb-14 leading-relaxed">Get notified when MoodSketch launches.</p>
        <form action="https://formspree.io/f/REPLACE_ME" method="POST" class="flex flex-col sm:flex-row gap-3 mb-5">
          <input type="email" name="email" placeholder="your@email.com" required
            class="flex-1 px-7 py-4 rounded-2xl bg-white/[0.05] border border-white/[0.08] text-white placeholder-white/20 focus:outline-none focus:border-mood-coral/50 text-base transition-all duration-300 font-light" />
          <button type="submit" class="cta-pulse px-9 py-4 rounded-2xl bg-mood-coral hover:bg-mood-coral/90 text-white font-display font-semibold text-[0.9rem] transition-all shadow-xl shadow-mood-coral/15 whitespace-nowrap">
            Notify me
          </button>
        </form>
        <p class="text-white/15 text-xs font-mono tracking-wide">No spam. Unsubscribe anytime.</p>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="bg-ink py-14 px-6 md:px-10 border-t border-white/[0.04]">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
        <Logo size={26} opacity="0.4" textSize="0.85rem" />
        <div class="flex items-center gap-10">
          <a href="https://sketchkit.app" class="text-sm text-white/25 hover:text-white/50 transition-colors duration-300">SketchKit</a>
          <a href="https://fieldsketch.app" class="text-sm text-white/25 hover:text-white/50 transition-colors duration-300">FieldSketch</a>
          <a href="/privacy" class="text-sm text-white/25 hover:text-white/50 transition-colors duration-300">Privacy</a>
        </div>
        <p class="text-[0.65rem] text-white/15 font-mono tracking-wider">&copy; 2026 SketchKit</p>
      </div>
    </footer>

  </div>
</Base>
