---
import Base from '../layouts/Base.astro';
---

<style is:global>
  /* Feature grid: 1 col mobile → 2 col md+ */
  .ms-feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 600px) {
    .ms-feature-grid { grid-template-columns: repeat(2, 1fr); }
  }
  /* Pricing grid */
  .ms-pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 580px) {
    .ms-pricing-grid { grid-template-columns: repeat(2, 1fr); }
  }
  /* Mobile hero padding */
  @media (max-width: 480px) {
    .ms-hero { padding-top: 96px !important; padding-bottom: 60px !important; }
    .ms-hero-icon { width: 100px !important; height: 100px !important; }
  }
</style>

<Base
  title="MoodSketch — Your Daily Creative Ritual"
  description="Draw your mood instead of writing about it. MoodSketch is a daily sketch journal app with prompts, expressive tools, and a beautiful creative archive."
>

  <!-- ═══════════════════════════════════════════════════
       NAV
  ══════════════════════════════════════════════════════ -->
  <nav style="position:fixed;top:0;width:100%;z-index:50;background:rgba(250,248,245,0.88);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-bottom:1px solid rgba(184,112,112,0.10);">
    <div style="max-width:1100px;margin:0 auto;padding:0 24px;height:60px;display:flex;align-items:center;justify-content:space-between;">
      <a href="https://sketchkit.app" style="font-family:'DM Sans',sans-serif;font-size:0.8rem;font-weight:500;color:#7A6560;text-decoration:none;display:flex;align-items:center;gap:5px;transition:color 0.2s;" onmouseover="this.style.color='#B87070'" onmouseout="this.style.color='#7A6560'">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        SketchKit
      </a>
      <span style="font-family:'Playfair Display',serif;font-weight:700;font-size:1.05rem;color:#2A2320;letter-spacing:-0.01em;">MoodSketch</span>
      <a href="https://fieldsketch.app" style="font-family:'DM Sans',sans-serif;font-size:0.8rem;font-weight:500;color:#7A6560;text-decoration:none;display:flex;align-items:center;gap:5px;transition:color 0.2s;" onmouseover="this.style.color='#B87070'" onmouseout="this.style.color='#7A6560'">
        FieldSketch
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════════ -->
  <section class="paper-grain" style="background:#FAF8F5;padding:120px 24px 80px;position:relative;overflow:hidden;min-height:100svh;display:flex;align-items:center;justify-content:center;">
    <!-- Warm radial glow behind icon -->
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-58%);width:600px;height:500px;background:radial-gradient(ellipse at center, rgba(232,207,200,0.60) 0%, rgba(250,248,245,0) 70%);pointer-events:none;z-index:0;"></div>
    <!-- Decorative drifting rings -->
    <div class="drift" style="position:absolute;top:20%;right:12%;width:80px;height:80px;border-radius:50%;border:1.5px solid rgba(184,112,112,0.12);animation-delay:-2s;"></div>
    <div class="drift" style="position:absolute;bottom:25%;left:9%;width:52px;height:52px;border-radius:50%;border:1px solid rgba(184,112,112,0.09);animation-delay:-5s;"></div>
    <div class="drift" style="position:absolute;top:38%;left:5%;width:28px;height:28px;border-radius:50%;background:rgba(184,112,112,0.07);animation-delay:-8s;"></div>
    <div class="drift" style="position:absolute;top:15%;left:30%;width:16px;height:16px;border-radius:50%;background:rgba(184,112,112,0.10);animation-delay:-3s;"></div>
    <!-- Small scattered dots -->
    <svg style="position:absolute;top:28%;right:20%;opacity:0.12;" width="8" height="8"><circle cx="4" cy="4" r="4" fill="#B87070"/></svg>
    <svg style="position:absolute;bottom:30%;right:8%;opacity:0.08;" width="14" height="14"><circle cx="7" cy="7" r="7" fill="#B87070"/></svg>
    <svg style="position:absolute;top:60%;left:20%;opacity:0.06;" width="6" height="6"><circle cx="3" cy="3" r="3" fill="#B87070"/></svg>

    <div class="hero-stagger" style="max-width:580px;width:100%;text-align:center;position:relative;z-index:2;">
      <!-- Label -->
      <p class="font-handwriting" style="font-size:1.25rem;color:#B87070;margin:0 0 28px;opacity:0.85;">For iPhone &amp; Android</p>

      <!-- App icon -->
      <div style="display:flex;justify-content:center;margin-bottom:28px;">
        <img
          src="/moodsketch-icon-transparent.png"
          alt="MoodSketch app icon"
          class="float-gentle icon-glow"
          style="width:128px;height:128px;border-radius:28%;display:block;"
        />
      </div>

      <!-- Headline -->
      <h1 class="font-serif" style="font-size:clamp(2.8rem,9vw,6.5rem);font-weight:800;line-height:1.0;letter-spacing:-0.025em;color:#2A2320;margin:0 0 20px;">
        Mood<em style="font-style:italic;font-weight:700;">Sketch</em>
      </h1>

      <!-- Subheadline -->
      <p class="font-sans" style="font-size:clamp(1.1rem,2.5vw,1.4rem);font-weight:500;color:#2A2320;margin:0 0 14px;line-height:1.3;">
        Your daily creative ritual.
      </p>

      <!-- Hook line -->
      <p class="font-sans" style="font-size:1.05rem;color:#7A6560;margin:0 0 44px;line-height:1.7;max-width:380px;margin-left:auto;margin-right:auto;font-weight:300;">
        You don't have to write about your feelings.<br/>Draw them.
      </p>

      <!-- CTAs -->
      <div style="display:flex;flex-direction:column;gap:12px;align-items:center;">
        <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
          <a href="#waitlist" class="btn-spring" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#B87070;color:#FAF8F5;border-radius:14px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.9rem;text-decoration:none;box-shadow:0 4px 18px rgba(184,112,112,0.30);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            App Store — Coming Soon
          </a>
          <a href="#waitlist" class="btn-spring" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:transparent;color:#7A6560;border:1.5px solid rgba(184,112,112,0.30);border-radius:14px;font-family:'DM Sans',sans-serif;font-weight:500;font-size:0.9rem;text-decoration:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Google Play — Coming Soon
          </a>
        </div>
        <p class="font-handwriting" style="font-size:1rem;color:#B87070;opacity:0.6;margin-top:4px;">join the waitlist below ↓</p>
      </div>
    </div>

    <!-- Bottom fade into next section -->
    <div style="position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(to bottom, transparent, #FAF8F5);pointer-events:none;z-index:3;"></div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       FEATURES
  ══════════════════════════════════════════════════════ -->
  <section style="background:#E8CFC8;padding:80px 24px;">
    <div style="max-width:1100px;margin:0 auto;">

      <div class="reveal" style="text-align:center;margin-bottom:56px;">
        <p class="font-handwriting" style="font-size:1.2rem;color:#9A5A5A;margin:0 0 10px;">What it does</p>
        <h2 class="font-serif" style="font-size:clamp(1.9rem,4vw,2.9rem);font-weight:800;color:#2A2320;margin:0;line-height:1.15;">
          What makes it <span class="rose-underline">different.</span>
        </h2>
      </div>

      <div class="stagger ms-feature-grid">

        <!-- Card 1 -->
        <div class="reveal card-tilt" style="background:#FAF8F5;border-radius:22px;padding:32px;box-shadow:0 4px 24px rgba(42,35,32,0.07),0 1px 4px rgba(42,35,32,0.04);">
          <div style="width:52px;height:52px;border-radius:14px;background:#E8CFC8;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:1.5rem;">🌅</div>
          <h3 class="font-serif" style="font-size:1.2rem;font-weight:700;color:#2A2320;margin:0 0 12px;line-height:1.2;">Daily Prompts</h3>
          <p class="font-sans" style="font-size:0.92rem;color:#7A6560;line-height:1.75;margin:0;">A new sketch prompt every day — loose enough to interpret, specific enough to be a starting point. You never start from nothing.</p>
        </div>

        <!-- Card 2 -->
        <div class="reveal card-tilt" style="background:#FAF8F5;border-radius:22px;padding:32px;box-shadow:0 4px 24px rgba(42,35,32,0.07),0 1px 4px rgba(42,35,32,0.04);">
          <div style="width:52px;height:52px;border-radius:14px;background:#E8CFC8;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:1.5rem;">🎨</div>
          <h3 class="font-serif" style="font-size:1.2rem;font-weight:700;color:#2A2320;margin:0 0 12px;line-height:1.2;">Tag Your Mood</h3>
          <p class="font-sans" style="font-size:0.92rem;color:#7A6560;line-height:1.75;margin:0;">Pick how you're feeling — Great, Good, Okay, Low, or Rough. Your sketches become a mood map over time. Patterns emerge that words never would.</p>
        </div>

        <!-- Card 3 -->
        <div class="reveal card-tilt" style="background:#FAF8F5;border-radius:22px;padding:32px;box-shadow:0 4px 24px rgba(42,35,32,0.07),0 1px 4px rgba(42,35,32,0.04);">
          <div style="width:52px;height:52px;border-radius:14px;background:#E8CFC8;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:1.5rem;">🔥</div>
          <h3 class="font-serif" style="font-size:1.2rem;font-weight:700;color:#2A2320;margin:0 0 12px;line-height:1.2;">Build Your Streak</h3>
          <p class="font-sans" style="font-size:0.92rem;color:#7A6560;line-height:1.75;margin:0;">Draw every day, watch your streak grow. Miss one, no guilt — just pick it back up. The ritual compounds into something worth keeping.</p>
        </div>

        <!-- Card 4 -->
        <div class="reveal card-tilt" style="background:#FAF8F5;border-radius:22px;padding:32px;box-shadow:0 4px 24px rgba(42,35,32,0.07),0 1px 4px rgba(42,35,32,0.04);">
          <div style="width:52px;height:52px;border-radius:14px;background:#E8CFC8;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:1.5rem;">📖</div>
          <h3 class="font-serif" style="font-size:1.2rem;font-weight:700;color:#2A2320;margin:0 0 12px;line-height:1.2;">Gallery Archive</h3>
          <p class="font-sans" style="font-size:0.92rem;color:#7A6560;line-height:1.75;margin:0;">Every sketch joins your scrolling calendar gallery — tagged by mood, organized by month. Your archive makes it all worth it.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       MOOD PALETTE SHOWCASE
  ══════════════════════════════════════════════════════ -->
  <section style="background:#FAF8F5;padding:80px 24px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,#E8CFC8,#B87070,#E8CFC8);opacity:0.6;"></div>

    <div style="max-width:800px;margin:0 auto;text-align:center;">
      <div class="reveal" style="margin-bottom:48px;">
        <p class="font-handwriting" style="font-size:1.2rem;color:#B87070;margin:0 0 10px;">The emotional spectrum</p>
        <h2 class="font-serif" style="font-size:clamp(1.9rem,4vw,2.9rem);font-weight:800;color:#2A2320;margin:0;line-height:1.15;">Every feeling gets a colour.</h2>
      </div>

      <!-- Mood swatches -->
      <div class="reveal" style="display:flex;flex-wrap:wrap;gap:16px;justify-content:center;margin-bottom:40px;">
        <div style="display:flex;flex-direction:column;align-items:center;gap:10px;">
          <div style="width:64px;height:64px;border-radius:50%;background:#7EC8A4;box-shadow:0 4px 16px rgba(126,200,164,0.35);"></div>
          <span class="font-handwriting" style="font-size:1rem;color:#2A2320;font-weight:600;">Great</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:10px;">
          <div style="width:64px;height:64px;border-radius:50%;background:#9BC4E2;box-shadow:0 4px 16px rgba(155,196,226,0.35);"></div>
          <span class="font-handwriting" style="font-size:1rem;color:#2A2320;font-weight:600;">Good</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:10px;">
          <div style="width:64px;height:64px;border-radius:50%;background:#E8CFC8;box-shadow:0 4px 16px rgba(232,207,200,0.35);border:1.5px solid rgba(184,112,112,0.15);"></div>
          <span class="font-handwriting" style="font-size:1rem;color:#2A2320;font-weight:600;">Okay</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:10px;">
          <div style="width:64px;height:64px;border-radius:50%;background:#C9A8C0;box-shadow:0 4px 16px rgba(201,168,192,0.35);"></div>
          <span class="font-handwriting" style="font-size:1rem;color:#2A2320;font-weight:600;">Low</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:10px;">
          <div style="width:64px;height:64px;border-radius:50%;background:#A0888E;box-shadow:0 4px 16px rgba(160,136,142,0.35);"></div>
          <span class="font-handwriting" style="font-size:1rem;color:#2A2320;font-weight:600;">Rough</span>
        </div>
      </div>

      <p class="reveal font-sans" style="font-size:1rem;color:#7A6560;max-width:420px;margin:0 auto;line-height:1.8;">Tag each sketch with a mood. Watch your emotional landscape take shape over weeks and months — in colour, not words.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       HOW IT WORKS
  ══════════════════════════════════════════════════════ -->
  <section style="background:#F0E3DE;padding:80px 24px;position:relative;overflow:hidden;">
    <!-- Decorative watercolour blobs -->
    <div style="position:absolute;top:-60px;right:-40px;width:300px;height:300px;background:radial-gradient(circle, rgba(184,112,112,0.10) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
    <div style="position:absolute;bottom:-40px;left:-30px;width:200px;height:200px;background:radial-gradient(circle, rgba(184,112,112,0.08) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>

    <div style="max-width:640px;margin:0 auto;position:relative;">
      <div class="reveal" style="text-align:center;margin-bottom:56px;">
        <p class="font-handwriting" style="font-size:1.2rem;color:#9A5A5A;margin:0 0 10px;">The Ritual</p>
        <h2 class="font-serif" style="font-size:clamp(1.9rem,4vw,2.9rem);font-weight:800;color:#2A2320;margin:0;line-height:1.15;">How it works.</h2>
      </div>

      <div style="display:flex;flex-direction:column;gap:0;">

        <!-- Step 1 -->
        <div class="reveal" style="display:flex;gap:24px;align-items:flex-start;position:relative;">
          <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:center;">
            <div style="width:52px;height:52px;border-radius:50%;background:#B87070;color:#FAF8F5;font-family:'Playfair Display',serif;font-weight:800;font-size:1.3rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(184,112,112,0.30);flex-shrink:0;">1</div>
            <div style="width:2px;height:52px;background:rgba(184,112,112,0.20);margin-top:4px;border-radius:2px;"></div>
          </div>
          <div style="padding-top:10px;padding-bottom:32px;">
            <h3 class="font-serif" style="font-size:1.3rem;font-weight:700;color:#2A2320;margin:0 0 10px;line-height:1.2;">Get a prompt</h3>
            <p class="font-sans" style="font-size:0.97rem;color:#7A6560;line-height:1.8;margin:0;">Open the app. Today's prompt is waiting — a word, a feeling, a concept. Something loose enough to interpret, specific enough to start.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="reveal" style="display:flex;gap:24px;align-items:flex-start;position:relative;transition-delay:0.12s;">
          <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:center;">
            <div style="width:52px;height:52px;border-radius:50%;background:#B87070;color:#FAF8F5;font-family:'Playfair Display',serif;font-weight:800;font-size:1.3rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(184,112,112,0.30);flex-shrink:0;">2</div>
            <div style="width:2px;height:52px;background:rgba(184,112,112,0.20);margin-top:4px;border-radius:2px;"></div>
          </div>
          <div style="padding-top:10px;padding-bottom:32px;">
            <h3 class="font-serif" style="font-size:1.3rem;font-weight:700;color:#2A2320;margin:0 0 10px;line-height:1.2;">Tag your mood &amp; sketch</h3>
            <p class="font-sans" style="font-size:0.97rem;color:#7A6560;line-height:1.8;margin:0;">Pick how you're feeling. Then draw — with expressive brushes, curated colour palettes, and pinch-to-zoom. No rules, no pressure.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="reveal" style="display:flex;gap:24px;align-items:flex-start;transition-delay:0.24s;">
          <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:center;">
            <div style="width:52px;height:52px;border-radius:50%;background:#B87070;color:#FAF8F5;font-family:'Playfair Display',serif;font-weight:800;font-size:1.3rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(184,112,112,0.30);flex-shrink:0;">3</div>
          </div>
          <div style="padding-top:10px;">
            <h3 class="font-serif" style="font-size:1.3rem;font-weight:700;color:#2A2320;margin:0 0 10px;line-height:1.2;">Watch it grow</h3>
            <p class="font-sans" style="font-size:0.97rem;color:#7A6560;line-height:1.8;margin:0;">Each sketch joins your calendar gallery — tagged by mood, organised by month. Your streak keeps you coming back. Your archive makes it worth it.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       EMOTIONAL PULL QUOTE
  ══════════════════════════════════════════════════════ -->
  <section style="background:#FAF8F5;padding:88px 24px;position:relative;overflow:hidden;">
    <!-- Large background quote mark -->
    <div class="font-serif" style="position:absolute;top:-40px;left:50%;transform:translateX(-50%);font-size:28rem;line-height:1;color:#E8CFC8;font-weight:800;pointer-events:none;user-select:none;opacity:0.5;">&ldquo;</div>

    <div class="reveal" style="max-width:680px;margin:0 auto;text-align:center;position:relative;z-index:2;">
      <p class="font-serif" style="font-size:clamp(1.5rem,3.5vw,2.4rem);font-style:italic;font-weight:600;color:#2A2320;line-height:1.4;margin:0 0 24px;">
        Not every feeling has words.<br/>
        Some of them just need<br/>
        a <span style="color:#B87070;" class="rose-underline">brushstroke.</span>
      </p>
      <p class="font-sans" style="font-size:0.95rem;color:#7A6560;margin:0;letter-spacing:0.02em;">That's what MoodSketch is for.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       PRICING
  ══════════════════════════════════════════════════════ -->
  <section style="background:#E8CFC8;padding:80px 24px;">
    <div style="max-width:720px;margin:0 auto;">
      <div class="reveal" style="text-align:center;margin-bottom:48px;">
        <p class="font-handwriting" style="font-size:1.2rem;color:#9A5A5A;margin:0 0 10px;">Pricing</p>
        <h2 class="font-serif" style="font-size:clamp(1.9rem,4vw,2.9rem);font-weight:800;color:#2A2320;margin:0 0 10px;line-height:1.15;">Simple pricing.</h2>
        <p class="font-sans" style="font-size:1rem;color:#7A6560;margin:0;">Start free. Go pro when you're ready.</p>
      </div>

      <div class="ms-pricing-grid">

        <!-- Free -->
        <div class="reveal" style="background:#FAF8F5;border-radius:22px;padding:36px;box-shadow:0 4px 24px rgba(42,35,32,0.07);">
          <p class="font-sans" style="font-size:0.8rem;font-weight:600;color:#7A6560;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 14px;">Free</p>
          <p class="font-serif" style="font-size:3.2rem;font-weight:800;color:#2A2320;line-height:1;margin:0 0 4px;">$0</p>
          <p class="font-sans" style="font-size:0.85rem;color:#7A6560;margin:0 0 28px;">Forever free</p>
          <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
            <li class="font-sans" style="font-size:0.9rem;color:#2A2320;display:flex;align-items:center;gap:10px;"><span style="color:#B87070;font-size:0.8rem;">✓</span> Daily prompt</li>
            <li class="font-sans" style="font-size:0.9rem;color:#2A2320;display:flex;align-items:center;gap:10px;"><span style="color:#B87070;font-size:0.8rem;">✓</span> Mood tagging</li>
            <li class="font-sans" style="font-size:0.9rem;color:#2A2320;display:flex;align-items:center;gap:10px;"><span style="color:#B87070;font-size:0.8rem;">✓</span> Streak counter</li>
            <li class="font-sans" style="font-size:0.9rem;color:#2A2320;display:flex;align-items:center;gap:10px;"><span style="color:#B87070;font-size:0.8rem;">✓</span> Curated colour palettes</li>
