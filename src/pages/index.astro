---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---
<Base
  title="MoodSketch — Your Daily Creative Ritual"
  description="Draw your mood instead of writing about it. MoodSketch is a daily sketch journal app with prompts, expressive tools, and a beautiful creative archive."
>
  <div class="min-h-screen">

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-mood-warm-white/80 backdrop-blur-xl border-b border-mood-coral/8">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="https://sketchkit.app" class="text-sm font-medium text-sketch-gray hover:text-ink transition-colors flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SketchKit
        </a>
        <span class="font-mood font-bold text-ink tracking-tight">MoodSketch</span>
        <a href="https://fieldsketch.app" class="text-sm font-medium text-sketch-gray hover:text-ink transition-colors flex items-center gap-1">
          FieldSketch
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="noise relative bg-gradient-to-br from-mood-coral to-mood-marigold text-white pt-32 pb-40 px-6 overflow-hidden">
      <!-- Painterly decorative elements -->
      <div class="absolute top-20 right-16 w-40 h-40 rounded-full bg-white/5 blur-2xl"></div>
      <div class="absolute bottom-24 left-10 w-56 h-56 rounded-full bg-mood-marigold/20 blur-3xl"></div>
      <div class="absolute top-1/3 right-1/3 w-24 h-24 sketch-ring"></div>
      <div class="absolute bottom-1/4 left-1/4 w-16 h-16 sketch-ring" style="animation-delay: 2s; border-color: rgba(255,255,255,0.08);"></div>
      <!-- Subtle hand-drawn SVG marks -->
      <svg class="absolute top-32 left-[15%] w-12 h-12 text-white/[0.06]" viewBox="0 0 48 48" fill="none">
        <path d="M8 24c8-16 24-16 32 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M12 28c6 10 18 10 24 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg class="absolute bottom-40 right-[20%] w-8 h-8 text-white/[0.08]" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="2"/>
        <circle cx="16" cy="16" r="4" fill="currentColor"/>
      </svg>

      <div class="max-w-4xl mx-auto text-center hero-stagger relative">
        <p class="font-mono text-xs tracking-[0.3em] uppercase text-white/40 mb-8">For iPhone & Android</p>

        <div class="flex justify-center mb-8">
          <img src="/moodsketch-icon.png" alt="MoodSketch app icon"
               class="w-24 h-24 rounded-[28%] shadow-2xl shadow-black/30 ring-4 ring-white/10" />
        </div>

        <h1 class="font-mood font-extrabold tracking-tight text-6xl sm:text-7xl md:text-[5.5rem] lg:text-[7rem] leading-[0.85] mb-6">
          MoodSketch
        </h1>

        <p class="text-white/90 text-2xl md:text-3xl font-display font-medium mb-4">Your daily creative ritual.</p>

        <p class="text-white/50 text-lg max-w-md mx-auto leading-relaxed mb-14">
          You don't have to write about your feelings. Draw them.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-white/20 backdrop-blur border border-white/25 text-white font-semibold text-base transition-all hover:bg-white/30">
            App Store &mdash; Coming Soon
          </button>
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-white/10 backdrop-blur border border-white/15 text-white/80 font-medium text-base transition-all hover:bg-white/20">
            Google Play &mdash; Coming Soon
          </button>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="bg-mood-warm-white py-28 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-mood-coral mb-4">Features</p>
          <h2 class="font-mood font-bold tracking-tight text-4xl md:text-5xl text-ink">What makes it different.</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-10">
          <div class="reveal text-center" style="transition-delay: 0s">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-coral/15 to-mood-marigold/10 flex items-center justify-center mx-auto mb-6">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F5764A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3 class="font-mood font-bold tracking-tight text-xl text-ink mb-3">Daily Prompts</h3>
            <p class="text-sketch-gray leading-relaxed">A new sketch prompt every day. Something to react to, something to interpret your own way. You never start from nothing.</p>
          </div>
          <div class="reveal text-center" style="transition-delay: 0.1s">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-marigold/15 to-mood-coral/10 flex items-center justify-center mx-auto mb-6">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#D94420" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </div>
            <h3 class="font-mood font-bold tracking-tight text-xl text-ink mb-3">Tag Your Mood</h3>
            <p class="text-sketch-gray leading-relaxed">Before you save, pick how you're feeling — Great, Good, Okay, Low, or Rough. Your sketches become a mood map over time.</p>
          </div>
          <div class="reveal text-center" style="transition-delay: 0.2s">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-lavender/30 to-mood-coral/10 flex items-center justify-center mx-auto mb-6">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C3B1E1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            </div>
            <h3 class="font-mood font-bold tracking-tight text-xl text-ink mb-3">Build Your Streak</h3>
            <p class="text-sketch-gray leading-relaxed">Draw every day, watch your streak grow. Miss one, no guilt — just pick it back up. The ritual compounds over time into something worth keeping.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="noise bg-mood-soft-blush py-28 px-6 relative">
      <!-- Subtle sketch decoration -->
      <svg class="absolute top-10 right-10 w-20 h-20 text-mood-coral/[0.06]" viewBox="0 0 80 80" fill="none">
        <circle cx="40" cy="40" r="30" stroke="currentColor" stroke-width="2" stroke-dasharray="8 6"/>
      </svg>

      <div class="max-w-3xl mx-auto relative">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-mood-coral mb-4">The Ritual</p>
          <h2 class="font-mood font-bold tracking-tight text-4xl md:text-5xl text-ink">How it works.</h2>
        </div>
        <div class="space-y-16">
          <div class="reveal flex gap-8 items-start">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-coral to-mood-marigold text-white font-mood font-extrabold text-2xl flex items-center justify-center shadow-lg shadow-mood-coral/20">1</div>
            <div>
              <h3 class="font-mood font-bold tracking-tight text-2xl text-ink mb-3">Get a prompt</h3>
              <p class="text-sketch-gray text-lg leading-relaxed">Open the app. Today's prompt is waiting — a word, a feeling, a concept. Something loose enough to interpret, specific enough to be a starting point.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 items-start" style="transition-delay: 0.12s">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-coral to-mood-marigold text-white font-mood font-extrabold text-2xl flex items-center justify-center shadow-lg shadow-mood-coral/20">2</div>
            <div>
              <h3 class="font-mood font-bold tracking-tight text-2xl text-ink mb-3">Tag your mood & sketch</h3>
              <p class="text-sketch-gray text-lg leading-relaxed">Pick how you're feeling. Then draw — with expressive brushes, curated color palettes, and pinch-to-zoom. No rules, no pressure.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 items-start" style="transition-delay: 0.24s">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-mood-lavender to-mood-coral/50 text-ink font-mood font-extrabold text-2xl flex items-center justify-center shadow-lg shadow-mood-lavender/20">3</div>
            <div>
              <h3 class="font-mood font-bold tracking-tight text-2xl text-ink mb-3">Watch it grow</h3>
              <p class="text-sketch-gray text-lg leading-relaxed">Each sketch joins your scrolling calendar gallery — tagged by mood, organized by month. Your streak keeps you coming back. Your archive makes it worth it.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Big Quote / Emotional section -->
    <section class="bg-mood-warm-white py-24 px-6">
      <div class="max-w-3xl mx-auto text-center reveal">
        <svg class="mx-auto mb-8 text-mood-coral/20" width="48" height="48" viewBox="0 0 48 48" fill="currentColor">
          <path d="M14 24H8c0-6.627 5.373-12 12-12v6c-3.314 0-6 2.686-6 6zm20 0h-6c0-6.627 5.373-12 12-12v6c-3.314 0-6 2.686-6 6z"/>
        </svg>
        <p class="font-mood font-bold text-3xl md:text-4xl text-ink leading-snug mb-6">
          Not every feeling has words.<br/>Some of them just need a brushstroke.
        </p>
        <p class="text-sketch-gray text-lg">That's what MoodSketch is for.</p>
      </div>
    </section>

    <!-- Pricing -->
    <section class="bg-mood-warm-white py-28 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-mood-coral mb-4">Pricing</p>
          <h2 class="font-mood font-bold tracking-tight text-4xl md:text-5xl text-ink mb-3">Simple pricing.</h2>
          <p class="text-sketch-gray text-lg">Start free. Go pro when you're ready.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Free -->
          <div class="reveal rounded-3xl p-8 border-2 border-light-rule bg-white">
            <p class="text-sketch-gray text-sm font-medium mb-2">Free</p>
            <p class="font-mood font-extrabold tracking-tight text-5xl text-ink mb-1">$0</p>
            <p class="text-sketch-gray text-sm mb-8">Forever free</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral font-bold">&#10003;</span> Daily prompt</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral font-bold">&#10003;</span> Mood tagging</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral font-bold">&#10003;</span> Streak counter</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral font-bold">&#10003;</span> Curated color palettes</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-mood-coral font-bold">&#10003;</span> Scrolling gallery archive</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/40"><span>&#10007;</span> Export (PDF/PNG)</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/40"><span>&#10007;</span> Custom themes</li>
            </ul>
            <button class="w-full py-3.5 rounded-2xl border-2 border-light-rule text-sketch-gray font-semibold text-sm hover:border-mood-coral hover:text-mood-coral transition-colors">
              Coming soon
            </button>
          </div>
          <!-- Pro -->
          <div class="reveal relative overflow-hidden rounded-3xl p-8 bg-gradient-to-br from-mood-coral to-mood-marigold text-white" style="transition-delay: 0.1s">
            <div class="absolute top-0 right-0 w-40 h-40 bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative">
              <p class="text-white/70 text-sm font-medium mb-2">Pro</p>
              <p class="font-mood font-extrabold tracking-tight text-5xl mb-1">$2.99<span class="text-2xl font-normal text-white/60">/mo</span></p>
              <p class="text-white/50 text-sm mb-8">or $19.99/yr — save 44%</p>
              <ul class="space-y-3 mb-8">
                <li class="flex items-center gap-3 text-sm"><span class="font-bold">&#10003;</span> Everything in Free</li>
                <li class="flex items-center gap-3 text-sm"><span class="font-bold">&#10003;</span> Unlimited archive</li>
                <li class="flex items-center gap-3 text-sm"><span class="font-bold">&#10003;</span> Full prompt library</li>
                <li class="flex items-center gap-3 text-sm"><span class="font-bold">&#10003;</span> Export to PDF & PNG</li>
                <li class="flex items-center gap-3 text-sm"><span class="font-bold">&#10003;</span> Custom themes</li>
                <li class="flex items-center gap-3 text-sm"><span class="font-bold">&#10003;</span> Early access to new features</li>
              </ul>
              <button class="cta-pulse w-full py-3.5 rounded-2xl bg-white text-mood-coral font-semibold text-sm hover:bg-white/90 transition-colors shadow-lg shadow-mood-marigold/30">
                Coming soon
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Email Capture -->
    <section class="noise bg-mood-plum py-28 px-6 relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] bg-mood-coral/10 rounded-full blur-[120px]"></div>
      <!-- Sketch decoration -->
      <svg class="absolute bottom-10 left-10 w-16 h-16 text-white/[0.04]" viewBox="0 0 64 64" fill="none">
        <path d="M12 32c10-20 30-20 40 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <div class="max-w-lg mx-auto text-center reveal relative">
        <p class="font-mono text-xs tracking-[0.3em] uppercase text-mood-coral/50 mb-6">Waitlist</p>
        <h2 class="font-mood font-bold tracking-tight text-4xl md:text-5xl text-white mb-4">Be first to draw.</h2>
        <p class="text-white/40 text-lg mb-12">Get notified when MoodSketch launches.</p>
        <form action="https://formspree.io/f/REPLACE_ME" method="POST" class="flex flex-col sm:flex-row gap-3 mb-4">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 px-6 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder-white/25 focus:outline-none focus:border-mood-coral/60 text-base transition-all"
          />
          <button
            type="submit"
            class="cta-pulse px-8 py-4 rounded-2xl bg-mood-coral hover:bg-mood-coral/90 text-white font-semibold text-base transition-all shadow-lg shadow-mood-coral/20 whitespace-nowrap"
          >
            Notify me
          </button>
        </form>
        <p class="text-white/20 text-sm">No spam. Unsubscribe anytime.</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink py-12 px-6 border-t border-white/5">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <Logo size={28} opacity="0.5" textSize="0.875rem" />
        <div class="flex items-center gap-8">
          <a href="https://sketchkit.app" class="text-sm text-white/30 hover:text-white/60 transition-colors">SketchKit</a>
          <a href="https://fieldsketch.app" class="text-sm text-white/30 hover:text-white/60 transition-colors">FieldSketch</a>
          <a href="/privacy" class="text-sm text-white/30 hover:text-white/60 transition-colors">Privacy</a>
        </div>
        <p class="text-xs text-white/20 font-mono">&copy; 2026 SketchKit</p>
      </div>
    </footer>

  </div>
</Base>
